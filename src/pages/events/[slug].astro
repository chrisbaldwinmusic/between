---
import events from '../../data/events.json';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return events.map(event => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;

// Determine action CTA
let actionLabel: string;
let actionHref: string;
let actionExternal = false;

if (event.status === 'soldout') {
  actionLabel = 'Sold out';
  actionHref = '';
} else if (event.status === 'past') {
  actionLabel = '';
  actionHref = '';
} else {
  const url = event.ticketing === 'free' ? event.registerUrl : event.ticketUrl;
  if (url) {
    actionLabel = event.ticketing === 'free' ? 'Register free' : 'Get tickets';
    actionHref = `${url}?utm_source=between&utm_medium=eventpage&utm_campaign=${event.slug}`;
    actionExternal = true;
  } else {
    actionLabel = 'Get notified when tickets go on sale';
    actionHref = `/#signup`;
  }
}

// Parse date safely (UTC)
const [y, m, d] = event.date.split('-').map(Number);
const dateObj = new Date(Date.UTC(y, m - 1, d));
const weekday = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][dateObj.getUTCDay()];
const longDate = `${weekday} ${d} ${event.month}`;
---

<BaseLayout
  title={`${event.name} — The Space Between`}
  description={event.blurb}
>
  <main id="main">

    <!-- ── Event hero ─────────────────────────────────────────────────── -->
    <div class="event-hero" style={`--accent: ${event.accent}`}>
      <div class="container event-hero__inner">
        <a href="/#the-year" class="event-hero__back">
          <span aria-hidden="true">←</span> Full programme
        </a>
        <p class="event-hero__month">{event.month}</p>
        <h1 class="event-hero__title">{event.name}</h1>
        <p class="event-hero__format">{event.format}</p>
      </div>
    </div>

    <!-- ── Event detail ────────────────────────────────────────────────── -->
    <div class="event-detail section-light">
      <div class="container event-detail__grid">

        <!-- Main content -->
        <div class="event-detail__main">
          <p class="event-detail__blurb">{event.blurb}</p>

          {actionLabel && (
            <div class="event-detail__cta">
              <a
                href={actionHref}
                class={`btn btn-primary event-detail__btn ${event.status === 'soldout' ? 'event-detail__btn--soldout' : ''}`}
                {...(actionExternal ? { rel: 'noopener noreferrer', target: '_blank' } : {})}
              >
                {actionLabel}
                {actionExternal && <span class="sr-only"> (opens in new tab)</span>}
              </a>
              {event.ticketing === 'ticketed' && event.priceFrom && (
                <p class="event-detail__price-note">From {event.priceFrom} per person</p>
              )}
              {event.ticketing === 'free' && (
                <p class="event-detail__price-note">This event is free to attend</p>
              )}
            </div>
          )}
        </div>

        <!-- Sidebar: date, venue, access -->
        <aside class="event-detail__sidebar" aria-label="Event details">

          <dl class="event-detail__facts">
            <div class="event-fact">
              <dt class="event-fact__label">Date</dt>
              <dd class="event-fact__value">{longDate}</dd>
            </div>

            <div class="event-fact">
              <dt class="event-fact__label">Venue</dt>
              <dd class="event-fact__value">{event.venue}</dd>
            </div>

            <div class="event-fact">
              <dt class="event-fact__label">Time of day</dt>
              <dd class="event-fact__value" style="text-transform: capitalize">{event.timeOfDay}</dd>
            </div>

            <div class="event-fact">
              <dt class="event-fact__label">Price</dt>
              <dd class="event-fact__value">
                {event.ticketing === 'free' ? 'Free' : `From ${event.priceFrom}`}
              </dd>
            </div>

            <div class="event-fact">
              <dt class="event-fact__label">Accessibility</dt>
              <dd class="event-fact__value">{event.access}</dd>
            </div>
          </dl>

        </aside>

      </div>
    </div>

    <!-- ── Back to programme ───────────────────────────────────────────── -->
    <div class="section-dark event-footer">
      <div class="container">
        <p class="event-footer__text">
          Part of <strong>The Space Between</strong> — ten events, all year, across Burton.
        </p>
        <a href="/#the-year" class="btn btn-ghost-dark">
          <span aria-hidden="true">←</span> See the full programme
        </a>
      </div>
    </div>

  </main>
</BaseLayout>

<style>
  /* ── Event hero ───────────────────────────────────────────────────────── */
  .event-hero {
    background: var(--ink);
    border-top: 5px solid var(--accent);
    padding-block: clamp(var(--space-10), 8vw, var(--space-16));
  }

  .event-hero__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .event-hero__back {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--body);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    transition: color 150ms var(--ease-out);
    width: fit-content;
  }
  .event-hero__back:hover { color: var(--paper); }
  .event-hero__back:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .event-hero__month {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin: 0;
  }

  .event-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    font-optical-sizing: auto;
    color: var(--paper);
    line-height: 1.05;
    max-width: 22ch;
    margin: 0;
  }

  .event-hero__format {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--body);
    margin: 0;
    max-width: 50ch;
  }

  /* ── Event detail ─────────────────────────────────────────────────────── */
  .section-light {
    background: var(--paper);
  }

  .event-detail {
    padding-block: clamp(var(--space-10), 7vw, var(--space-16));
  }

  .event-detail__grid {
    display: grid;
    gap: clamp(var(--space-8), 5vw, var(--space-12));
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .event-detail__grid {
      grid-template-columns: 1fr 320px;
      align-items: start;
    }
  }

  .event-detail__blurb {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0 0 var(--space-8);
  }

  .event-detail__cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .event-detail__btn {
    font-size: var(--text-base);
    padding: 0.85rem 2rem;
  }
  .event-detail__btn--soldout {
    opacity: 0.5;
    pointer-events: none;
    cursor: not-allowed;
  }

  .event-detail__price-note {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin: 0;
  }

  /* ── Sidebar: facts ───────────────────────────────────────────────────── */
  .event-detail__sidebar {
    background: #fff;
    border-radius: var(--radius-md);
    padding: var(--space-6);
    box-shadow: 0 2px 16px rgba(26, 18, 18, 0.08);
  }

  .event-detail__facts {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin: 0;
  }

  .event-fact {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(26, 18, 18, 0.08);
  }
  .event-fact:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .event-fact__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--body);
  }

  .event-fact__value {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--ink);
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
  }

  /* ── Footer band ──────────────────────────────────────────────────────── */
  .event-footer {
    padding-block: clamp(var(--space-8), 5vw, var(--space-12));
  }

  .event-footer .container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
  }

  @media (min-width: 600px) {
    .event-footer .container {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .event-footer__text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--body);
    margin: 0;
    max-width: 50ch;
  }
  .event-footer__text strong {
    color: var(--paper);
    font-weight: 600;
  }
</style>
