---
// Compact signup strip — placed just before the Footer.
// Uses the same MailerLite form and WhatsApp link as SignupSection.
// The MailerLite universal.js script is already loaded by SignupSection;
// calling ml('account', ...) a second time is safe (the library no-ops).

const WA_URL = 'https://chat.whatsapp.com/DTBdI2ur34oKah3pOn2zpm'
             + '?utm_source=between&utm_medium=footer-strip&utm_campaign=whatsapp';
---

<div class="signup-strip" aria-label="Sign up to The Space Between community">
  <div class="container">

    <div class="signup-strip__inner">

      <div class="signup-strip__copy">
        <p class="signup-strip__heading">Stay with us.</p>
        <p class="signup-strip__sub">
          One event a month. Join and hear about every one first.
        </p>
      </div>

      <div class="signup-strip__actions">

        <!-- Compact MailerLite embed -->
        <div class="signup-strip__form">
          <div class="ml-embedded" data-form="147122363674134026"></div>
        </div>

        <span class="signup-strip__or" aria-hidden="true">or</span>

        <!-- WhatsApp -->
        <a
          href={WA_URL}
          class="signup-strip__wa"
          rel="noopener noreferrer"
          target="_blank"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Join on WhatsApp
          <span class="sr-only">(opens WhatsApp — free to join and leave any time)</span>
        </a>

      </div>

    </div>

  </div>
</div>

<!-- Re-initialise MailerLite in case this component loads without SignupSection -->
<script is:inline>
if (typeof ml !== 'undefined') {
  ml('account', '1114181');
} else {
  (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
  .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
  n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
  (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
  ml('account', '1114181');
}
</script>

<style>
  /* ── Strip wrapper ────────────────────────────────────────────────────── */
  .signup-strip {
    background: var(--ink-soft);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: clamp(var(--space-8), 6vw, var(--space-12));
  }

  /* ── Inner layout ─────────────────────────────────────────────────────── */
  .signup-strip__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .signup-strip__inner {
      flex-direction: row;
      align-items: center;
      gap: clamp(var(--space-8), 4vw, var(--space-12));
    }
    .signup-strip__copy {
      flex: 0 0 min(35%, 300px);
    }
    .signup-strip__actions {
      flex: 1;
    }
  }

  /* ── Copy ─────────────────────────────────────────────────────────────── */
  .signup-strip__heading {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 1.75rem);
    font-weight: 700;
    font-optical-sizing: auto;
    color: var(--paper);
    letter-spacing: -0.015em;
    line-height: 1.1;
    margin-bottom: var(--space-2);
  }

  .signup-strip__sub {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--body);
    line-height: 1.55;
    margin: 0;
  }

  /* ── Actions ──────────────────────────────────────────────────────────── */
  .signup-strip__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }

  @media (min-width: 600px) {
    .signup-strip__actions {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
      gap: var(--space-4);
    }
  }

  .signup-strip__form {
    flex: 1;
    min-width: 240px;
  }

  .signup-strip__or {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--body);
    flex-shrink: 0;
  }

  /* MailerLite overrides (dark context) */
  .signup-strip__form :global(label) {
    color: var(--body) !important;
    font-size: var(--text-xs) !important;
    font-family: var(--font-body) !important;
    font-weight: 600 !important;
  }
  .signup-strip__form :global(input[type="email"]),
  .signup-strip__form :global(input[type="text"]) {
    background: rgba(255,255,255,0.07) !important;
    border: 1.5px solid var(--line) !important;
    color: var(--paper) !important;
    font-family: var(--font-body) !important;
    font-size: var(--text-sm) !important;
    border-radius: var(--radius-sm) !important;
    padding: 0.65rem 1rem !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }
  .signup-strip__form :global(input::placeholder) {
    color: var(--body) !important;
  }
  .signup-strip__form :global(input:focus) {
    outline: 3px solid var(--ember) !important;
    outline-offset: 2px !important;
    border-color: transparent !important;
    background: rgba(255,255,255,0.12) !important;
  }
  .signup-strip__form :global(button[type="submit"]),
  .signup-strip__form :global(.ml-form-embedSubmit button) {
    background: var(--red) !important;
    color: var(--paper) !important;
    font-family: var(--font-body) !important;
    font-size: var(--text-sm) !important;
    font-weight: 700 !important;
    border: none !important;
    border-radius: var(--radius-sm) !important;
    padding: 0.65rem 1.25rem !important;
    cursor: pointer !important;
    width: 100% !important;
    white-space: nowrap !important;
  }
  .signup-strip__form :global(.ml-form-embedWrapper),
  .signup-strip__form :global(.ml-form-embedBody) {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    box-shadow: none !important;
  }

  /* ── WhatsApp button (strip) ──────────────────────────────────────────── */
  .signup-strip__wa {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: #25D366;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    padding: 0.65rem 1.1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 150ms var(--ease-out);
  }
  .signup-strip__wa:hover { background: #1da851; }
  .signup-strip__wa:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .signup-strip__wa { transition: none; }
  }
</style>
