---
// No props — static section content
const doors = [
  {
    icon: '♪',
    audience: 'Audiences',
    heading: 'Come to an event',
    body: 'The simplest thing is just to show up. One event a month, free or from £7.50, all across Burton. Join the community and hear about every one first.',
    ctaLabel: 'Join the community',
    ctaHref: '#signup',
    external: false,
  },
  {
    icon: '♫',
    audience: 'Artists',
    heading: 'Want to play?',
    body: "We're building a year of events and we want to hear from Burton's musicians — emerging acts, community groups, established artists. Get in touch.",
    ctaLabel: 'hello@sonicboom.org.uk',
    ctaHref: 'mailto:hello@sonicboom.org.uk?subject=Want%20to%20play%20%E2%80%94%20The%20Space%20Between',
    external: true,
  },
  {
    icon: '◈',
    audience: 'Partners & press',
    heading: 'Back The Space Between',
    body: 'Businesses, organisations and community groups can partner with us. For sponsorship, media enquiries or collaboration, we want to hear from you.',
    ctaLabel: 'hello@sonicboom.org.uk',
    ctaHref: 'mailto:hello@sonicboom.org.uk?subject=Partnership%20%E2%80%94%20The%20Space%20Between',
    external: true,
  },
] as const;
---

<section id="get-involved" class="getinvolved-section" aria-labelledby="getinvolved-heading">
  <div class="container">

    <h2 id="getinvolved-heading" class="getinvolved-heading">Get involved</h2>

    <div class="getinvolved-doors">
      {doors.map(door => (
        <article class="door-card">

          <span class="door-card__icon" aria-hidden="true">{door.icon}</span>

          <p class="door-card__audience">{door.audience}</p>

          <h3 class="door-card__title">{door.heading}</h3>

          <p class="door-card__body">{door.body}</p>

          <a
            href={door.ctaHref}
            class="door-card__cta"
            {...(door.external
              ? { rel: 'noopener noreferrer' }
              : {})}
          >
            {door.ctaLabel}
            <span class="door-card__arrow" aria-hidden="true">→</span>
            {door.external && <span class="sr-only"> (opens email client)</span>}
          </a>

        </article>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Section ──────────────────────────────────────────────────────────── */
  .getinvolved-section {
    background: var(--paper);
    padding-block: clamp(var(--space-12), 9vw, var(--space-20));
  }

  /* ── Heading ──────────────────────────────────────────────────────────── */
  .getinvolved-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    font-optical-sizing: auto;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: clamp(var(--space-8), 5vw, var(--space-12));
  }

  /* ── Cards grid ───────────────────────────────────────────────────────── */
  .getinvolved-doors {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .getinvolved-doors {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Door card ────────────────────────────────────────────────────────── */
  .door-card {
    background: var(--ink);
    border-radius: var(--radius-md);
    padding: clamp(var(--space-6), 4vw, var(--space-8));
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: transform 200ms var(--ease-out);
  }

  .door-card:hover { transform: translateY(-2px); }

  @media (prefers-reduced-motion: reduce) {
    .door-card,
    .door-card:hover { transform: none; transition: none; }
  }

  .door-card__icon {
    font-size: 1.75rem;
    color: var(--ember);
    line-height: 1;
  }

  .door-card__audience {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--body);
    margin: 0;
  }

  .door-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.5vw, 1.4rem);
    font-weight: 700;
    font-optical-sizing: auto;
    line-height: 1.2;
    color: var(--paper);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .door-card__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--body);
    flex: 1;
    margin: 0;
  }

  /* Micro-CTA */
  .door-card__cta {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ember);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    width: fit-content;
    margin-top: auto;
    transition: color 150ms var(--ease-out), gap 150ms var(--ease-out);
    word-break: break-all; /* for email addresses on small screens */
  }
  .door-card__cta:hover {
    color: var(--paper);
    gap: 0.55em;
  }
  .door-card__cta:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .door-card__arrow {
    flex-shrink: 0;
    transition: transform 150ms var(--ease-out);
    word-break: normal;
  }
  .door-card__cta:hover .door-card__arrow {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .door-card__cta,
    .door-card__arrow { transition: none; }
    .door-card__cta:hover .door-card__arrow { transform: none; }
  }
</style>
