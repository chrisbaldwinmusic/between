---
// MailerLite credentials (public client-side embed values — not secrets)
const ML_ACCOUNT  = '1114181';
const ML_FORM_ID  = '147122363674134026';

// WhatsApp Community invite link
const WA_URL = 'https://chat.whatsapp.com/DTBdI2ur34oKah3pOn2zpm'
             + '?utm_source=between&utm_medium=signup&utm_campaign=whatsapp';

interface Props {
  /** Show the section heading + intro. Strip variant passes false. */
  showHeading?: boolean;
}
const { showHeading = true } = Astro.props;
---

<section
  id="signup"
  class="signup-section"
  aria-labelledby={showHeading ? 'signup-heading' : undefined}
>
  <div class="container">

    {showHeading && (
      <header class="signup-header">
        <h2 id="signup-heading" class="signup-heading">
          Join the community
        </h2>
        <p class="signup-sub">
          Free to join. Hear about every event before it's announced —
          straight to your inbox or your phone.
        </p>
      </header>
    )}

    <div class="signup-options">

      <!-- ── Email (MailerLite) ───────────────────────────────────────── -->
      <div class="signup-option signup-option--email">
        <h3 class="signup-option__heading">
          <span class="signup-option__icon" aria-hidden="true">✉</span>
          By email
        </h3>
        <p class="signup-option__desc">
          We'll send you event news, early ticket links, and nothing else.
          Unsubscribe any time.
        </p>

        <!--
          MailerLite universal embed.
          Form is configured in the MailerLite dashboard:
          - Ensure each field has a visible <label> (not placeholder-as-label)
          - Enable double opt-in
          Account: 1114181  |  Form: 147122363674134026
        -->
        <div class="ml-form-wrapper">
          <div class="ml-embedded" data-form={ML_FORM_ID}></div>
        </div>
      </div>

      <!-- ── Divider ─────────────────────────────────────────────────── -->
      <div class="signup-divider" aria-hidden="true">
        <span class="signup-divider__line"></span>
        <span class="signup-divider__or">or</span>
        <span class="signup-divider__line"></span>
      </div>

      <!-- ── WhatsApp ────────────────────────────────────────────────── -->
      <div class="signup-option signup-option--wa">
        <h3 class="signup-option__heading">
          <span class="signup-option__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </span>
          On WhatsApp
        </h3>
        <p class="signup-option__desc">
          Join our WhatsApp Community for event reminders and behind-the-scenes
          updates from Sonic Boom. Free to join — leave any time.
        </p>

        <a
          href={WA_URL}
          class="btn signup-wa-btn"
          rel="noopener noreferrer"
          target="_blank"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Join the WhatsApp Community
          <span class="sr-only">(opens WhatsApp — free to join and leave)</span>
        </a>

      </div>

    </div>

    <!-- Privacy note -->
    <p class="signup-privacy">
      We use your email to tell you about The Space Between events and news.
      We never sell your data.
      <a href="/privacy" class="signup-privacy__link">Privacy notice →</a>
    </p>

  </div>
</section>

<!-- MailerLite universal embed script — runs once per page load -->
<script is:inline>
(function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
.push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
(window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
ml('account', '1114181');
</script>

<style>
  /* ── Section ──────────────────────────────────────────────────────────── */
  .signup-section {
    background: var(--paper);
    padding-block: clamp(var(--space-12), 9vw, var(--space-20));
  }

  /* ── Header ───────────────────────────────────────────────────────────── */
  .signup-header {
    margin-bottom: clamp(var(--space-8), 5vw, var(--space-12));
    max-width: 56ch;
  }

  .signup-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    font-optical-sizing: auto;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: var(--space-4);
  }

  .signup-sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0;
    max-width: 52ch;
  }

  /* ── Options layout ───────────────────────────────────────────────────── */
  .signup-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-items: stretch;
  }

  @media (min-width: 680px) {
    .signup-options {
      flex-direction: row;
      align-items: flex-start;
      gap: 0;
    }
    .signup-option--email {
      flex: 1;
      padding-right: clamp(var(--space-6), 4vw, var(--space-10));
    }
    .signup-option--wa {
      flex: 0 0 min(42%, 380px);
      padding-left: clamp(var(--space-6), 4vw, var(--space-10));
    }
  }

  /* ── Option card ──────────────────────────────────────────────────────── */
  .signup-option {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .signup-option__heading {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
  }

  .signup-option__icon {
    color: var(--red);
    font-size: 1.1em;
    line-height: 1;
    flex-shrink: 0;
  }

  .signup-option__desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 44ch;
    margin: 0;
  }

  /* ── Divider ──────────────────────────────────────────────────────────── */
  .signup-divider {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-3);
    color: var(--body);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .signup-divider__line {
    flex: 1;
    height: 1px;
    background: rgba(26, 18, 18, 0.12);
  }

  @media (min-width: 680px) {
    .signup-divider {
      flex-direction: column;
      width: 1px;
      min-height: 200px;
      gap: var(--space-4);
    }
    .signup-divider__line {
      width: 1px;
      height: auto;
      flex: 1;
    }
    .signup-divider__or {
      writing-mode: vertical-lr;
    }
  }

  /* ── MailerLite form overrides ────────────────────────────────────────── */
  /* These styles nudge MailerLite's generated output toward our brand.
     For complete control, also customise the form in the MailerLite dashboard
     (set visible labels, not placeholder-as-label; enable double opt-in). */
  .ml-form-wrapper :global(.ml-form-embedWrapper) {
    background: transparent !important;
    border: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
    box-shadow: none !important;
  }
  .ml-form-wrapper :global(.ml-form-embedBody),
  .ml-form-wrapper :global(.ml-form-embedBody .ml-form-embedContent) {
    padding: 0 !important;
    margin: 0 !important;
  }
  .ml-form-wrapper :global(label) {
    font-family: var(--font-body) !important;
    font-size: var(--text-sm) !important;
    font-weight: 600 !important;
    color: var(--ink) !important;
    margin-bottom: var(--space-1) !important;
  }
  .ml-form-wrapper :global(input[type="email"]),
  .ml-form-wrapper :global(input[type="text"]) {
    font-family: var(--font-body) !important;
    font-size: var(--text-base) !important;
    background: #fff !important;
    border: 1.5px solid rgba(26, 18, 18, 0.2) !important;
    border-radius: var(--radius-sm) !important;
    color: var(--ink) !important;
    padding: 0.75rem 1rem !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }
  .ml-form-wrapper :global(input:focus) {
    outline: 3px solid var(--ember) !important;
    outline-offset: 2px !important;
    border-color: transparent !important;
  }
  .ml-form-wrapper :global(button[type="submit"]),
  .ml-form-wrapper :global(.ml-form-embedSubmit button) {
    background: var(--red) !important;
    color: var(--paper) !important;
    font-family: var(--font-body) !important;
    font-size: var(--text-base) !important;
    font-weight: 700 !important;
    border: none !important;
    border-radius: var(--radius-sm) !important;
    padding: 0.75rem 1.5rem !important;
    cursor: pointer !important;
    width: 100% !important;
    transition: background 150ms var(--ease-out) !important;
  }
  .ml-form-wrapper :global(button[type="submit"]:hover) {
    background: var(--ink) !important;
  }
  .ml-form-wrapper :global(.ml-form-successBody) {
    font-family: var(--font-body) !important;
    color: var(--ink) !important;
    padding: var(--space-4) !important;
    background: rgba(232, 162, 61, 0.1) !important;
    border-radius: var(--radius-sm) !important;
  }

  /* ── WhatsApp button ──────────────────────────────────────────────────── */
  .signup-wa-btn {
    background: #25D366;  /* WhatsApp green — contrast with --ink text: 8.8:1 ✓ */
    color: var(--ink);
    font-size: var(--text-sm);
    padding: 0.75rem 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-weight: 700;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 150ms var(--ease-out), transform 150ms var(--ease-out);
    align-self: flex-start;
  }
  .signup-wa-btn:hover {
    background: #1da851;
    transform: translateY(-1px);
  }
  .signup-wa-btn:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .signup-wa-btn,
    .signup-wa-btn:hover { transform: none; transition: none; }
  }

  /* ── Privacy note ─────────────────────────────────────────────────────── */
  .signup-privacy {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--body);
    margin-top: clamp(var(--space-8), 4vw, var(--space-12));
    line-height: 1.6;
  }

  .signup-privacy__link {
    color: var(--ink-soft);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .signup-privacy__link:hover { color: var(--ink); }
  .signup-privacy__link:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>
