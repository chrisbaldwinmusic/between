---
// DemandMeter — §6.6 / Step 8
// Renders inside the dark AmbitionTeaser section (--ink-soft background).
// Manages state in JS: question → voting → voted | error.
// Persists vote choice in localStorage so returning visitors skip the question.
---

<div class="demand-meter" data-state="question" aria-label="Venue demand meter">

  <!-- Screen-reader live region for state announcements -->
  <p class="sr-only" aria-live="polite" aria-atomic="true" id="dm-status"></p>

  <!-- ── Question ──────────────────────────────────────────────────────── -->
  <div class="dm-pane dm-pane--question">
    <p class="dm-question" id="dm-q">
      Would you use a permanent grassroots music venue in Burton?
    </p>
    <div class="dm-choices" role="group" aria-labelledby="dm-q">
      <button class="dm-btn dm-btn--yes" data-choice="yes" type="button">
        Yes, I would
      </button>
      <button class="dm-btn dm-btn--maybe" data-choice="maybe" type="button">
        Maybe / not sure
      </button>
    </div>
    <p class="dm-intro-note">
      One tap — no sign-up required. Your answer is added to the
      demand count immediately.
    </p>
  </div>

  <!-- ── Voting (loading) ───────────────────────────────────────────────── -->
  <div class="dm-pane dm-pane--voting" aria-hidden="true">
    <span class="dm-spinner" aria-hidden="true"></span>
    <p class="dm-loading-text">Adding your voice…</p>
  </div>

  <!-- ── Result ────────────────────────────────────────────────────────── -->
  <div class="dm-pane dm-pane--voted">

    <!-- Meter bar -->
    <div
      class="dm-meter-bar"
      role="meter"
      aria-label="Percentage who said yes"
      aria-valuenow="0"
      aria-valuemin="0"
      aria-valuemax="100"
      id="dm-meter"
    >
      <div class="dm-bar-track">
        <div class="dm-bar-fill"></div>
      </div>
      <p class="dm-bar-label">
        <strong class="dm-pct-text">0</strong>%
        <span class="dm-bar-desc"> of respondents said yes</span>
      </p>
    </div>

    <!-- Total count -->
    <p class="dm-total-line">
      <strong class="dm-total-text">0</strong>
      <span> voices counted so far</span>
    </p>

    <!-- Thanks line -->
    <p class="dm-thanks">
      Your voice — <span class="dm-chosen"></span> — has been added. Thank you.
    </p>

    <!-- Postcode (optional) -->
    <div class="dm-postcode">
      <form class="dm-postcode__form" novalidate>
        <div class="dm-postcode__field">
          <label for="dm-postcode-input" class="dm-postcode__label">
            Add your postcode
            <span class="dm-postcode__opt">(optional — helps show demand is local)</span>
          </label>
          <div class="dm-postcode__row">
            <input
              type="text"
              id="dm-postcode-input"
              name="postcode"
              class="dm-postcode__input"
              autocomplete="postal-code"
              spellcheck="false"
              maxlength="8"
              placeholder="e.g. DE13"
              aria-describedby="dm-postcode-hint"
            />
            <button type="submit" class="dm-postcode__submit">Add</button>
          </div>
          <p id="dm-postcode-hint" class="dm-postcode__hint">
            We only keep the outward code (e.g. DE13). Never stored against your name.
          </p>
        </div>
      </form>
      <p class="dm-postcode__done" hidden>Postcode added — thanks.</p>
    </div>

    <!-- Signup nudge -->
    <p class="dm-nudge">
      <a href="#signup" class="dm-nudge__link">Join the community</a>
      to hear what happens with this data and what comes next.
    </p>

  </div>

  <!-- ── Error ──────────────────────────────────────────────────────────── -->
  <div class="dm-pane dm-pane--error">
    <p class="dm-error-text">
      Something went wrong — your vote wasn't recorded. Please try again.
    </p>
    <button class="dm-retry" type="button">Try again</button>
  </div>

</div>

<style>
  /* ── Outer container ──────────────────────────────────────────────────── */
  .demand-meter {
    background: rgba(255, 255, 255, 0.04);
    border: 1.5px solid var(--line);
    border-radius: var(--radius-md);
    padding: clamp(var(--space-6), 4vw, var(--space-8));
    display: flex;
    flex-direction: column;
  }

  /* ── State pane visibility ────────────────────────────────────────────── */
  .dm-pane { display: none; }
  .demand-meter[data-state="question"] .dm-pane--question { display: flex; flex-direction: column; gap: var(--space-5); }
  .demand-meter[data-state="voting"]   .dm-pane--voting   { display: flex; flex-direction: column; align-items: center; gap: var(--space-4); padding-block: var(--space-8); }
  .demand-meter[data-state="voted"]    .dm-pane--voted    { display: flex; flex-direction: column; gap: var(--space-5); }
  .demand-meter[data-state="error"]    .dm-pane--error    { display: flex; flex-direction: column; gap: var(--space-4); }

  /* ── Question ─────────────────────────────────────────────────────────── */
  .dm-question {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 700;
    font-optical-sizing: auto;
    line-height: 1.3;
    color: var(--paper);
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* ── Vote buttons ─────────────────────────────────────────────────────── */
  .dm-choices {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .dm-btn {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 700;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    border: 1.5px solid transparent;
    cursor: pointer;
    flex: 1;
    min-width: 140px;
    transition: background 150ms var(--ease-out), color 150ms var(--ease-out), transform 100ms var(--ease-out);
    line-height: 1;
  }
  .dm-btn:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .dm-btn { transition: background 0ms, color 0ms, transform 0ms; }
  }

  .dm-btn--yes {
    background: var(--red);
    color: var(--paper);  /* 5.15:1 ✓ */
  }
  .dm-btn--yes:hover {
    background: #a80d26;
    transform: translateY(-1px);
  }

  .dm-btn--maybe {
    background: transparent;
    color: var(--paper);
    border-color: var(--line);
  }
  .dm-btn--maybe:hover {
    border-color: var(--body);
    background: rgba(255,255,255,0.05);
    transform: translateY(-1px);
  }

  .dm-intro-note {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--body);
    line-height: 1.55;
    margin: 0;
  }

  /* ── Voting / spinner ─────────────────────────────────────────────────── */
  .dm-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid rgba(232, 162, 61, 0.2);
    border-top-color: var(--ember);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    display: block;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .dm-spinner { animation: none; border-top-color: var(--ember); }
  }

  .dm-loading-text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--body);
    margin: 0;
  }

  /* ── Result — meter bar ───────────────────────────────────────────────── */
  .dm-meter-bar {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .dm-bar-track {
    height: 12px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    overflow: hidden;
  }

  .dm-bar-fill {
    height: 100%;
    width: 0%; /* JS sets this */
    background: linear-gradient(to right, var(--red), var(--ember));
    border-radius: 6px;
    transition: width 1.2s cubic-bezier(0.25, 0, 0.25, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .dm-bar-fill { transition: none; }
  }

  .dm-bar-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--body);
    margin: 0;
  }

  .dm-pct-text {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    font-optical-sizing: auto;
    color: var(--ember);
    display: block;
    line-height: 1;
    margin-bottom: var(--space-1);
  }

  /* ── Count ────────────────────────────────────────────────────────────── */
  .dm-total-line {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--body);
    margin: 0;
  }
  .dm-total-text {
    font-weight: 700;
    color: var(--paper);
    font-variant-numeric: tabular-nums;
  }

  /* ── Thanks ───────────────────────────────────────────────────────────── */
  .dm-thanks {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--body);
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: rgba(232, 162, 61, 0.08);
    border-left: 3px solid var(--ember);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    line-height: 1.55;
  }
  .dm-chosen {
    font-weight: 700;
    color: var(--paper);
  }

  /* ── Postcode ─────────────────────────────────────────────────────────── */
  .dm-postcode__label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--body);
    margin-bottom: var(--space-2);
  }
  .dm-postcode__opt {
    font-weight: 400;
    display: block;
    margin-top: var(--space-1);
  }

  .dm-postcode__row {
    display: flex;
    gap: var(--space-2);
  }

  .dm-postcode__input {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    background: rgba(255,255,255,0.07);
    border: 1.5px solid var(--line);
    border-radius: var(--radius-sm);
    color: var(--paper);
    padding: 0.55rem 0.875rem;
    flex: 1;
    min-width: 0;
    text-transform: uppercase;
  }
  .dm-postcode__input::placeholder { color: var(--body); text-transform: none; }
  .dm-postcode__input:focus {
    outline: 3px solid var(--ember);
    outline-offset: 2px;
    border-color: transparent;
    background: rgba(255,255,255,0.1);
  }

  .dm-postcode__submit {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    background: var(--line);
    color: var(--paper);
    border: none;
    border-radius: var(--radius-sm);
    padding: 0.55rem 1rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 150ms var(--ease-out);
  }
  .dm-postcode__submit:hover { background: var(--body); color: var(--ink); }
  .dm-postcode__submit:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 3px;
  }

  .dm-postcode__hint {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--body);
    line-height: 1.5;
    margin-top: var(--space-2);
    margin-bottom: 0;
  }

  .dm-postcode__done {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--ember);
    font-weight: 600;
    margin: 0;
  }

  /* ── Nudge ────────────────────────────────────────────────────────────── */
  .dm-nudge {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--body);
    margin: 0;
    line-height: 1.55;
  }
  .dm-nudge__link {
    color: var(--ember);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .dm-nudge__link:hover { color: var(--paper); }
  .dm-nudge__link:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ── Error ────────────────────────────────────────────────────────────── */
  .dm-error-text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--body);
    margin: 0;
  }
  .dm-retry {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    background: var(--red);
    color: var(--paper);
    border: none;
    border-radius: var(--radius-sm);
    padding: 0.6rem 1.25rem;
    cursor: pointer;
    width: fit-content;
  }
  .dm-retry:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 3px;
  }
</style>

<script>
  const meter     = document.querySelector<HTMLElement>('.demand-meter');
  const statusEl  = document.getElementById('dm-status');
  if (!meter) throw new Error('DemandMeter: root element missing');

  // ─── State ────────────────────────────────────────────────────────────────
  let counts = { total: 0, yes: 0, maybe: 0, yesPct: 0 };
  let userChoice = localStorage.getItem('tsb-voted'); // 'yes'|'maybe'|'already'|null
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function announce(msg: string) { if (statusEl) statusEl.textContent = msg; }

  // ─── Fetch current counts ─────────────────────────────────────────────────
  async function fetchCounts() {
    try {
      const res = await fetch('/api/results');
      if (res.ok) counts = await res.json() as typeof counts;
    } catch { /* silent — zeroes stay */ }
  }

  // ─── Populate result UI ───────────────────────────────────────────────────
  function showResult(choice: string | null) {
    meter.dataset.state = 'voted';

    const fillEl  = meter.querySelector<HTMLElement>('.dm-bar-fill');
    const meterEl = document.getElementById('dm-meter');
    const pctEl   = meter.querySelector<HTMLElement>('.dm-pct-text');
    const totalEl = meter.querySelector<HTMLElement>('.dm-total-text');
    const chosenEl = meter.querySelector<HTMLElement>('.dm-chosen');

    if (pctEl)    pctEl.textContent   = String(counts.yesPct);
    if (totalEl)  totalEl.textContent = counts.total.toLocaleString('en-GB');
    if (chosenEl) chosenEl.textContent = choice === 'yes' ? 'yes' : choice === 'maybe' ? 'maybe / not sure' : 'already counted';
    if (meterEl)  meterEl.setAttribute('aria-valuenow', String(counts.yesPct));

    // Animate fill
    if (fillEl) {
      if (prefersReduced) {
        fillEl.style.width = `${counts.yesPct}%`;
      } else {
        fillEl.style.width = '0%';
        requestAnimationFrame(() => requestAnimationFrame(() => {
          fillEl.style.width = `${counts.yesPct}%`;
        }));
      }
    }

    // Optional: count up the total number
    if (!prefersReduced && totalEl && counts.total > 1) {
      animateCount(totalEl, 0, counts.total, 1000);
    }

    announce(`${counts.yesPct}% said yes. ${counts.total.toLocaleString('en-GB')} people have responded.`);
  }

  // ─── Count-up animation ───────────────────────────────────────────────────
  function animateCount(el: HTMLElement, from: number, to: number, ms: number) {
    const start = performance.now();
    function tick(now: number) {
      const t = Math.min((now - start) / ms, 1);
      const n = Math.round(from + (to - from) * (1 - (1 - t) ** 3));
      el.textContent = n.toLocaleString('en-GB');
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  // ─── Vote ─────────────────────────────────────────────────────────────────
  meter.querySelectorAll<HTMLButtonElement>('.dm-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const choice = btn.dataset.choice as 'yes' | 'maybe';
      meter.dataset.state = 'voting';
      announce('Submitting your response…');

      try {
        const res  = await fetch('/api/vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ choice }),
        });
        const data = await res.json() as { ok: boolean; alreadyVoted?: boolean; total: number; yes: number; maybe: number; yesPct: number };

        if (data.ok || data.alreadyVoted) {
          counts     = { total: data.total, yes: data.yes, maybe: data.maybe, yesPct: data.yesPct };
          userChoice = data.alreadyVoted ? 'already' : choice;
          localStorage.setItem('tsb-voted', userChoice);
          showResult(userChoice);
        } else {
          throw new Error('vote rejected');
        }
      } catch {
        meter.dataset.state = 'error';
        announce('Something went wrong. Please try again.');
      }
    });
  });

  // ─── Postcode ─────────────────────────────────────────────────────────────
  const pcForm = meter.querySelector<HTMLFormElement>('.dm-postcode__form');
  const pcDone = meter.querySelector<HTMLElement>('.dm-postcode__done');

  pcForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input   = pcForm.querySelector<HTMLInputElement>('input[name="postcode"]');
    const postcode = input?.value.trim();
    if (!postcode) { input?.focus(); return; }

    try {
      await fetch('/api/vote', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ postcodeOnly: true, postcode }),
      });
    } catch { /* silent — thank them anyway */ }

    pcForm.hidden = true;
    if (pcDone) pcDone.hidden = false;
    announce('Postcode added — thank you.');
  });

  // ─── Retry ────────────────────────────────────────────────────────────────
  meter.querySelector('.dm-retry')?.addEventListener('click', () => {
    meter.dataset.state = 'question';
    announce('');
  });

  // ─── Initialise ───────────────────────────────────────────────────────────
  (async () => {
    await fetchCounts();
    if (userChoice) {
      showResult(userChoice);
    } else {
      meter.dataset.state = 'question';
    }
  })();
</script>
