---

<footer class="site-footer section-dark" role="contentinfo">
  <div class="container site-footer__inner">

    <!-- Brand + sign-off -->
    <div class="site-footer__brand">
      <p class="site-footer__name">The Space Between</p>
      <p class="site-footer__org">Sonic Boom Music CIC</p>
      <p class="site-footer__signoff"><em>Believe in the Power of Music.</em></p>
    </div>

    <!-- Links -->
    <nav class="site-footer__nav" aria-label="Footer navigation">
      <ul role="list" class="site-footer__nav-list">
        <li><a href={`https://sonicboom.org.uk?${UTM}&utm_campaign=sonicboom`} target="_blank" rel="noopener noreferrer">sonicboom.org.uk</a></li>
        <li><a href={`https://festival.sonicboom.org.uk?${UTM}&utm_campaign=festival`} target="_blank" rel="noopener noreferrer">festival.sonicboom.org.uk</a></li>
        <li><a href="/privacy">Privacy notice</a></li>
        <li><a href="/accessibility">Accessibility</a></li>
        <li><a href="mailto:hello@sonicboom.org.uk">hello@sonicboom.org.uk</a></li>
      </ul>
    </nav>

    <!-- Socials -->
    <div class="site-footer__socials">
      <p class="site-footer__socials-label" id="footer-socials-label">Follow us</p>
      <ul role="list" class="site-footer__social-list" aria-labelledby="footer-socials-label">
        {socials.map(({ label, href, svg }) => (
          <li>
            <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} class="site-footer__social-link">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                <Fragment set:html={svg} />
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <div class="site-footer__legal container">
    <p>Registered in England. Company no. <span class="sr-only">to be confirmed</span><span aria-hidden="true">—</span></p>
    <p>Burton upon Trent, Staffordshire</p>
  </div>
</footer>

<style>
  .site-footer {
    padding-top: var(--space-16);
    padding-bottom: var(--space-10);
    border-top: 1px solid var(--line);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  /* ── Brand ─────────────────────────────────────── */
  .site-footer__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--paper);
    max-width: none;
    margin-bottom: var(--space-1);
  }
  .site-footer__org {
    font-size: var(--text-sm);
    color: var(--body);
    font-weight: 500;
    max-width: none;
    margin-bottom: var(--space-4);
  }
  .site-footer__signoff {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    font-style: italic;
    color: var(--ember);
    max-width: none;
  }

  /* ── Nav ────────────────────────────────────────── */
  .site-footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .site-footer__nav-list a {
    font-size: var(--text-sm);
    color: var(--body);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }
  .site-footer__nav-list a:hover { color: var(--ember); }

  /* ── Socials ────────────────────────────────────── */
  .site-footer__socials-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--body);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    max-width: none;
    margin-bottom: var(--space-3);
  }
  .site-footer__social-list {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .site-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    color: var(--body);
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }
  .site-footer__social-link:hover {
    color: var(--ember);
    border-color: var(--ember);
  }
  .site-footer__social-link svg {
    width: 1rem;
    height: 1rem;
  }

  /* ── Legal ──────────────────────────────────────── */
  .site-footer__legal {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .site-footer__legal p {
    font-size: var(--text-xs);
    color: var(--line);
    max-width: none;
  }

  /* ── Desktop grid ───────────────────────────────── */
  @media (min-width: 768px) {
    .site-footer__inner {
      grid-template-columns: 2fr 1fr 1fr;
      align-items: start;
    }
  }
</style>
