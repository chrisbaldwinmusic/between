---
// TODO: Replace with Ticket Tailor Founding Membership link when available
const FOUNDING_MEMBER_URL = '#signup';
---

<section id="membership" class="membership-section" aria-labelledby="membership-heading">
  <div class="container">

    <div class="membership-inner">

      <!-- Copy -->
      <div class="membership-copy">
        <h2 id="membership-heading" class="membership-heading">
          Founding Membership
        </h2>

        <p class="membership-body">
          Founding Membership is membership of The Space Between community — the people
          who show up, year-round, and build the case together that Burton deserves more.
        </p>

        <p class="membership-body">
          It is not membership of a venue. A permanent home for grassroots music
          in Burton is <strong>our ambition</strong>. We're working to build the business
          case — with funders, the council, and the community. Every Founding Member is
          evidence that the demand is real.
        </p>

        <p class="membership-body">
          Back the year-round programme. Back the campaign. Be one of the first people
          to say: Burton is serious about this.
        </p>

        <p class="membership-launch">
          <span class="membership-launch__icon" aria-hidden="true">◆</span>
          Founding Membership launches at{' '}
          <a class="membership-launch__link" href="/events/winter-sounds">Winter Sounds</a>,
          5 December 2026. Sign up below to hear about it first.
        </p>
      </div>

      <!-- Card -->
      <div class="membership-card" aria-label="Founding Membership details">

        <p class="membership-card__label" aria-hidden="true">Founding Member</p>

        <ul class="membership-benefits" role="list" aria-label="What you get">
          {[
            'Hear about every event before it\'s announced publicly',
            'Priority tickets when they go on sale',
            'Invitation to members\' events and conversations about what comes next',
            'Your name in the programme (if you\'d like it)',
            'You\'re part of the evidence — every member is counted',
          ].map(benefit => (
            <li class="membership-benefit">
              <span class="benefit-tick" aria-hidden="true">✓</span>
              {benefit}
            </li>
          ))}
        </ul>

        <div class="membership-price">
          <p class="membership-price__label">Membership price</p>
          <p class="membership-price__value">TBC — announced at Winter Sounds</p>
        </div>

        <a
          href={FOUNDING_MEMBER_URL}
          class="btn btn-primary membership-cta"
        >
          Become a Founding Member
        </a>

        <p class="membership-note">
          {/* TODO: Update FOUNDING_MEMBER_URL to Ticket Tailor link (see CONTENT.md) */}
          Available from December 2026. Sign up to be notified the moment it launches.
        </p>

      </div>

    </div>

  </div>
</section>

<style>
  /* ── Section ──────────────────────────────────────────────────────────── */
  .membership-section {
    background: var(--paper);
    padding-block: clamp(var(--space-12), 9vw, var(--space-20));
  }

  /* ── Inner layout ─────────────────────────────────────────────────────── */
  .membership-inner {
    display: flex;
    flex-direction: column;
    gap: clamp(var(--space-10), 6vw, var(--space-14));
  }

  @media (min-width: 900px) {
    .membership-inner {
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(var(--space-10), 5vw, var(--space-14));
    }
    .membership-copy {
      flex: 1;
    }
    .membership-card {
      flex: 0 0 min(44%, 420px);
    }
  }

  /* ── Copy ─────────────────────────────────────────────────────────────── */
  .membership-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    font-optical-sizing: auto;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: var(--space-6);
  }

  .membership-body {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.1rem);
    line-height: 1.75;
    color: var(--ink-soft);
    max-width: 54ch;
    margin-bottom: var(--space-5);
  }
  .membership-body strong {
    color: var(--ink);
    font-weight: 700;
  }

  .membership-launch {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    margin-top: var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: rgba(200, 16, 46, 0.06);
    border-left: 3px solid var(--red);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  .membership-launch__icon {
    color: var(--red);
    flex-shrink: 0;
    margin-top: 0.15em;
  }
  .membership-launch__link {
    color: var(--ink);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .membership-launch__link:hover { color: var(--red); }
  .membership-launch__link:focus-visible {
    outline: 3px solid var(--ember);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ── Card ─────────────────────────────────────────────────────────────── */
  .membership-card {
    background: var(--ink);
    border-radius: var(--radius-md);
    padding: clamp(var(--space-6), 4vw, var(--space-8));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .membership-card__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ember);
    margin: 0;
  }

  /* ── Benefits ─────────────────────────────────────────────────────────── */
  .membership-benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .membership-benefit {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--body);
  }

  .benefit-tick {
    flex-shrink: 0;
    color: var(--ember);
    font-weight: 700;
    margin-top: 0.1em;
    line-height: 1.55;
  }

  /* ── Price ────────────────────────────────────────────────────────────── */
  .membership-price {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .membership-price__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--body);
    margin: 0;
  }

  .membership-price__value {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.5vw, 1.3rem);
    font-weight: 700;
    color: var(--paper);
    font-optical-sizing: auto;
    margin: 0;
  }

  /* ── CTA ──────────────────────────────────────────────────────────────── */
  .membership-cta {
    display: block;
    text-align: center;
    padding: 0.875rem 1.5rem;
    font-size: var(--text-base);
  }

  .membership-note {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--body);
    line-height: 1.55;
    margin: 0;
    text-align: center;
  }
</style>
